{
  "$schema": "https://raw.githubusercontent.com/nicoh-at-github/tauri-v2-schema/main/src/tauri.conf.schema.json",
  "productName": "PortKill",
  "version": "0.1.0",
  "identifier": "dev.chrlss.portkill",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "tooltip": "PortKill - Port Manager"
    },
    "windows": [
      {
        "title": "PortKill",
        "width": 420,
        "height": 520,
        "decorations": false,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "RWQiA/BisVV1d1Dih/nf7/Sq37SVXmQ6egxaYmo3PXKG5GGWjcISPpk8",
      "endpoints": [
        "https://github.com/chrlss11/portkill/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
